{
  "family": "todo-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::825765391206:role/todo-task-execution-role",
  "taskRoleArn": "arn:aws:iam::825765391206:role/todo-task-role",
  "runtimePlatform": {
    "operatingSystemFamily": "LINUX",
    "cpuArchitecture": "X86_64"
  },
  "containerDefinitions": [
    {
      "name": "app",
      "image": "<IMAGE1_NAME>",
      "essential": true,
      "portMappings": [
        { "containerPort": 8080, "protocol": "tcp" }
      ],
      "environment": [
        { "name": "SERVER_PORT", "value": "8080" },
        { "name": "SPRING_DATASOURCE_URL", "value": "jdbc:postgresql://todo-db-proxy.proxy-ctogw4uqw6z5.eu-central-1.rds.amazonaws.com:5432/todo?sslmode=require" },
        { "name": "SPRING_DATASOURCE_USERNAME", "value": "todoadmin" },
        { "name": "SPRING_DATA_REDIS_HOST", "value": "todo-redis.0jbnwf.0001.euc1.cache.amazonaws.com" },
        { "name": "SPRING_DATA_REDIS_PORT", "value": "6379" }
      ],
      "secrets": [
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:825765391206:secret:todo/db-credentials-IgpHM3:password::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/todo",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "app"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -q -O /dev/null http://localhost:8080/actuator/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}